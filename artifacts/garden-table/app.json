{
  "expo": {
    "name": "Garden Table",
    "slug": "garden-table",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "garden-table",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F2EB"
    },
    "ios": {
      "bundleIdentifier": "com.mfarrugg.gardentable",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mfarrugg.gardentable"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "static",
      "name": "Garden Table",
      "shortName": "Garden",
      "description": "Book the shared garden table",
      "themeColor": "#2D5A27",
      "backgroundColor": "#F5F2EB",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a2e04557-eb7a-4f9f-9c3b-7cecc743e6b8"
      }
    }
  }
}
